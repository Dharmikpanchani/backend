{
  "env": {
    "node": true,
    "es6": true,
    "browser": true,
    "commonjs": true
  },
  "extends": ["eslint:recommended", "airbnb-base"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "globals": {
    "process": "readonly"
  },
  "plugins": ["node"],
  "rules": {
    "no-console": "on",
    "semi": ["error", "never"],
    "node/no-unsupported-features/es-builtins": [
      "error",
      {
        "version": 12
      }
    ]
  }
}
